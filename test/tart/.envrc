#!/usr/bin/sh
#
# Configure how to connect to this vm
export HOSTNAME="lorien"
export USERNAME="galadriel"

AWS_DEFAULT_REGION=$(aws configure get region)
export AWS_DEFAULT_REGION
echo ""
echo "Using AWS region: $AWS_DEFAULT_REGION"

IPV4_ADDRESS=$(ansible-inventory --list | jq --raw-output "._meta.hostvars.$HOSTNAME.ansible_host")
export IPV4_ADDRESS
echo "IP address of $HOSTNAME: $IPV4_ADDRESS"

echo ""
echo "To connect and establish an RDP and an SSH tunnel, run:"
echo "ssh -L 3389:localhost:3389 -L 8022:localhost:22 $USERNAME@$IPV4_ADDRESS"
