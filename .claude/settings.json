{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -n --rawfile agents AGENTS.md --rawfile constitution .specify/memory/constitution.md '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:(\"=== AGENTS.md ===\\n\"+$agents+\"\\n=== .specify/memory/constitution.md ===\\n\"+$constitution)}}'",
            "statusMessage": "Injecting AGENTS.md and constitution..."
          }
        ],
        "matcher": ""
      }
    ]
  }
}